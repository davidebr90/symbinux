msgid "Identify"
msgstr "識別"

msgid "Read model, IMEI and firmware"
msgstr "モデル、IMEI、ファームウェアを読み取る"

msgid "Phonebook"
msgstr "電話帳"

msgid "Import / export contacts"
msgstr "連絡先のインポート / エクスポート"

msgid "SMS"
msgstr "SMS"

msgid "Read and send messages"
msgstr "メッセージの読み取りと送信"

msgid "Netmonitor"
msgstr "Netmonitor"

msgid "Network diagnostics"
msgstr "ネットワーク診断"

msgid "Advanced"
msgstr "詳細"

msgid "Raw USB/Bluetooth device list"
msgstr "USB/Bluetooth デバイスの一覧（生データ）"

msgid "Rescan the selected channel"
msgstr "選択したチャンネルを再スキャン"

msgid "Automatic"
msgstr "自動"

msgid "Light"
msgstr "ライト"

msgid "Dark"
msgstr "ダーク"

msgid "Appearance"
msgstr "外観"

msgid "Language"
msgstr "言語"

msgid "About Symbinux"
msgstr "Symbinux について"

msgid "Connect over a serial cable (/dev/ttyUSB*) to read phone identity."
msgstr "シリアルケーブル（/dev/ttyUSB*）で接続して端末情報を読み取ります。"

msgid "This function is not wired up yet on this channel."
msgstr "この機能はこのチャンネルではまだ実装されていません。"

msgid "Scanning Bluetooth…"
msgstr "Bluetooth をスキャン中…"

msgid "No Bluetooth devices found"
msgstr "Bluetooth デバイスが見つかりません"

msgid "Make sure Bluetooth is on and nearby devices are discoverable."
msgstr "Bluetooth がオンになっていること、また近くのデバイスが検出可能であることを確認してください。"

msgid "Scanning Wi-Fi…"
msgstr "Wi-Fi をスキャン中…"

msgid "No Wi-Fi networks found"
msgstr "Wi-Fi ネットワークが見つかりません"

msgid "No wireless networks are in range."
msgstr "範囲内に無線ネットワークがありません。"

msgid "Detecting devices…"
msgstr "デバイスを検出中…"

msgid "Core not available"
msgstr "コアが利用できません"

msgid "No phone or cable detected"
msgstr "端末またはケーブルが検出されません"

msgid "Connect a Nokia phone via a DKU-2/CA-42 cable, then press the refresh button. Use Advanced to inspect every USB device."
msgstr "DKU-2/CA-42 ケーブルで Nokia 端末を接続し、更新ボタンを押してください。すべての USB デバイスを確認するには「詳細」を使用します。"

msgid "paired"
msgstr "ペア設定済み"

msgid "Scanning USB…"
msgstr "USB をスキャン中…"

msgid "No USB devices visible to the host."
msgstr "ホストから認識できる USB デバイスがありません。"

msgid "Connected USB devices"
msgstr "接続されている USB デバイス"

msgid "Advanced diagnostics"
msgstr "詳細診断"

msgid "Close"
msgstr "閉じる"

msgid "Talk to legacy Nokia phones over FBUS/MBUS on modern Linux."
msgstr "最新の Linux 上で FBUS/MBUS 経由により旧型 Nokia 端末と通信します。"

msgid "Identifying…"
msgstr "識別中…"

msgid "Phone identity"
msgstr "端末情報"

msgid "No reply."
msgstr "応答がありません。"

msgid "No serial port found — connect a DKU-2/CA-42 cable and try again."
msgstr "シリアルポートが見つかりません — DKU-2/CA-42 ケーブルを接続してもう一度お試しください。"

msgid "Contacts"
msgstr "連絡先"

msgid "Fetching contacts…"
msgstr "連絡先を取得中…"

msgid "No contacts."
msgstr "連絡先がありません。"

msgid "Model"
msgstr "モデル"

msgid "Firmware"
msgstr "ファームウェア"

msgid "Date"
msgstr "日付"

msgid "Identify"
msgstr "Identificeren"

msgid "Read model, IMEI and firmware"
msgstr "Model, IMEI en firmware uitlezen"

msgid "Phonebook"
msgstr "Telefoonboek"

msgid "Import / export contacts"
msgstr "Contacten importeren / exporteren"

msgid "SMS"
msgstr "SMS"

msgid "Read and send messages"
msgstr "Berichten lezen en verzenden"

msgid "Netmonitor"
msgstr "Netmonitor"

msgid "Network diagnostics"
msgstr "Netwerkdiagnose"

msgid "Advanced"
msgstr "Geavanceerd"

msgid "Raw USB/Bluetooth device list"
msgstr "Ruwe USB-/Bluetooth-apparaatlijst"

msgid "Rescan the selected channel"
msgstr "Geselecteerd kanaal opnieuw scannen"

msgid "Automatic"
msgstr "Automatisch"

msgid "Light"
msgstr "Licht"

msgid "Dark"
msgstr "Donker"

msgid "Appearance"
msgstr "Weergave"

msgid "Language"
msgstr "Taal"

msgid "About Symbinux"
msgstr "Over Symbinux"

msgid "Connect over a serial cable (/dev/ttyUSB*) to read phone identity."
msgstr "Maak verbinding via een seriële kabel (/dev/ttyUSB*) om de telefoonidentiteit uit te lezen."

msgid "This function is not wired up yet on this channel."
msgstr "Deze functie is nog niet beschikbaar op dit kanaal."

msgid "Scanning Bluetooth…"
msgstr "Bluetooth scannen…"

msgid "No Bluetooth devices found"
msgstr "Geen Bluetooth-apparaten gevonden"

msgid "Make sure Bluetooth is on and nearby devices are discoverable."
msgstr "Zorg dat Bluetooth aanstaat en apparaten in de buurt vindbaar zijn."

msgid "Scanning Wi-Fi…"
msgstr "Wi-Fi scannen…"

msgid "No Wi-Fi networks found"
msgstr "Geen wifinetwerken gevonden"

msgid "No wireless networks are in range."
msgstr "Geen draadloze netwerken binnen bereik."

msgid "Detecting devices…"
msgstr "Apparaten detecteren…"

msgid "Core not available"
msgstr "Kern niet beschikbaar"

msgid "No phone or cable detected"
msgstr "Geen telefoon of kabel gedetecteerd"

msgid "Connect a Nokia phone via a DKU-2/CA-42 cable, then press the refresh button. Use Advanced to inspect every USB device."
msgstr "Sluit een Nokia-telefoon aan met een DKU-2/CA-42-kabel en druk daarna op de vernieuwknop. Gebruik Geavanceerd om elk USB-apparaat te inspecteren."

msgid "paired"
msgstr "gekoppeld"

msgid "Scanning USB…"
msgstr "USB scannen…"

msgid "No USB devices visible to the host."
msgstr "Geen USB-apparaten zichtbaar voor de host."

msgid "Connected USB devices"
msgstr "Verbonden USB-apparaten"

msgid "Advanced diagnostics"
msgstr "Geavanceerde diagnose"

msgid "Close"
msgstr "Sluiten"

msgid "Talk to legacy Nokia phones over FBUS/MBUS on modern Linux."
msgstr "Communiceer met oude Nokia-telefoons via FBUS/MBUS op modern Linux."

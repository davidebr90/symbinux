msgid "Scanning Bluetooth…"
msgstr "Analyse Bluetooth…"

msgid "No Bluetooth devices found"
msgstr "Aucun périphérique Bluetooth trouvé"

msgid "Make sure Bluetooth is on and nearby devices are discoverable."
msgstr "Assurez-vous que le Bluetooth est activé et que les appareils à proximité sont détectables."

msgid "Scanning Wi-Fi…"
msgstr "Analyse Wi-Fi…"


msgid "Connect over a serial cable (/dev/ttyUSB*) to read phone identity."
msgstr "Connectez-vous via un câble série (/dev/ttyUSB*) pour lire l'identité du téléphone."

msgid "This function is not wired up yet on this channel."
msgstr "Cette fonction n'est pas encore disponible sur ce canal."

#, python-format
msgid "%s scanning not available yet"
msgstr "Analyse %s pas encore disponible"

msgid "This channel is on the roadmap. USB is fully supported today."
msgstr "Ce canal est prévu dans la feuille de route. L'USB est entièrement pris en charge aujourd'hui."

msgid "Core not available"
msgstr "Cœur non disponible"

msgid "No phone or cable detected"
msgstr "Aucun téléphone ou câble détecté"

msgid "Connect a Nokia phone via a DKU-2/CA-42 cable, then press the refresh button. Use Advanced to inspect every USB device."
msgstr "Connectez un téléphone Nokia avec un câble DKU-2/CA-42, puis appuyez sur le bouton d'actualisation. Utilisez Avancé pour inspecter tous les périphériques USB."

msgid "Advanced diagnostics"
msgstr "Diagnostic avancé"

msgid "No USB devices visible to the host."
msgstr "Aucun périphérique USB visible pour l'hôte."

msgid "Connected USB devices"
msgstr "Périphériques USB connectés"

msgid "Close"
msgstr "Fermer"

msgid "Talk to legacy Nokia phones over FBUS/MBUS on modern Linux."
msgstr "Communiquez avec les téléphones Nokia anciens via FBUS/MBUS sur Linux moderne."

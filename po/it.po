msgid "Identify"
msgstr "Identifica"

msgid "Read model, IMEI and firmware"
msgstr "Leggi modello, IMEI e firmware"

msgid "Phonebook"
msgstr "Rubrica"

msgid "Import / export contacts"
msgstr "Importa / esporta contatti"

msgid "SMS"
msgstr "SMS"

msgid "Read and send messages"
msgstr "Leggi e invia messaggi"

msgid "Netmonitor"
msgstr "Netmonitor"

msgid "Network diagnostics"
msgstr "Diagnostica di rete"

msgid "Advanced"
msgstr "Avanzate"

msgid "Raw USB/Bluetooth device list"
msgstr "Elenco grezzo dispositivi USB/Bluetooth"

msgid "Rescan the selected channel"
msgstr "Riscansiona il canale selezionato"

msgid "Automatic"
msgstr "Automatico"

msgid "Light"
msgstr "Chiaro"

msgid "Dark"
msgstr "Scuro"

msgid "Appearance"
msgstr "Aspetto"

msgid "Language"
msgstr "Lingua"

msgid "About Symbinux"
msgstr "Informazioni su Symbinux"

msgid "Connect over a serial cable (/dev/ttyUSB*) to read phone identity."
msgstr "Collega via cavo seriale (/dev/ttyUSB*) per leggere l'identità del telefono."

msgid "This function is not wired up yet on this channel."
msgstr "Questa funzione non è ancora disponibile su questo canale."

msgid "Scanning Bluetooth…"
msgstr "Scansione Bluetooth…"

msgid "No Bluetooth devices found"
msgstr "Nessun dispositivo Bluetooth trovato"

msgid "Make sure Bluetooth is on and nearby devices are discoverable."
msgstr "Assicurati che il Bluetooth sia attivo e i dispositivi vicini siano rilevabili."

msgid "Scanning Wi-Fi…"
msgstr "Scansione Wi-Fi…"

msgid "No Wi-Fi networks found"
msgstr "Nessuna rete Wi-Fi trovata"

msgid "No wireless networks are in range."
msgstr "Nessuna rete wireless a portata."

msgid "Detecting devices…"
msgstr "Rilevamento dispositivi…"

msgid "Core not available"
msgstr "Core non disponibile"

msgid "No phone or cable detected"
msgstr "Nessun telefono o cavo rilevato"

msgid "Connect a Nokia phone via a DKU-2/CA-42 cable, then press the refresh button. Use Advanced to inspect every USB device."
msgstr "Collega un telefono Nokia con un cavo DKU-2/CA-42, poi premi il pulsante di aggiornamento. Usa Avanzate per ispezionare ogni dispositivo USB."

msgid "paired"
msgstr "associato"

msgid "Scanning USB…"
msgstr "Scansione USB…"

msgid "No USB devices visible to the host."
msgstr "Nessun dispositivo USB visibile all'host."

msgid "Connected USB devices"
msgstr "Dispositivi USB collegati"

msgid "Advanced diagnostics"
msgstr "Diagnostica avanzata"

msgid "Close"
msgstr "Chiudi"

msgid "Talk to legacy Nokia phones over FBUS/MBUS on modern Linux."
msgstr "Comunica con telefoni Nokia legacy via FBUS/MBUS su Linux moderno."

msgid "Identifying…"
msgstr "Identificazione…"

msgid "Phone identity"
msgstr "Identità telefono"

msgid "No reply."
msgstr "Nessuna risposta."

msgid "No serial port found — connect a DKU-2/CA-42 cable and try again."
msgstr "Nessuna porta seriale trovata — collega un cavo DKU-2/CA-42 e riprova."

msgid "Contacts"
msgstr "Contatti"

msgid "Fetching contacts…"
msgstr "Recupero contatti…"

msgid "No contacts."
msgstr "Nessun contatto."

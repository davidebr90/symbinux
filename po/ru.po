msgid "Identify"
msgstr "Идентифицировать"

msgid "Read model, IMEI and firmware"
msgstr "Считать модель, IMEI и прошивку"

msgid "Phonebook"
msgstr "Телефонная книга"

msgid "Import / export contacts"
msgstr "Импорт / экспорт контактов"

msgid "SMS"
msgstr "SMS"

msgid "Read and send messages"
msgstr "Чтение и отправка сообщений"

msgid "Netmonitor"
msgstr "Netmonitor"

msgid "Network diagnostics"
msgstr "Диагностика сети"

msgid "Advanced"
msgstr "Дополнительно"

msgid "Raw USB/Bluetooth device list"
msgstr "Полный список устройств USB/Bluetooth"

msgid "Rescan the selected channel"
msgstr "Пересканировать выбранный канал"

msgid "Automatic"
msgstr "Автоматически"

msgid "Light"
msgstr "Светлая"

msgid "Dark"
msgstr "Тёмная"

msgid "Appearance"
msgstr "Внешний вид"

msgid "Language"
msgstr "Язык"

msgid "About Symbinux"
msgstr "О программе Symbinux"

msgid "Connect over a serial cable (/dev/ttyUSB*) to read phone identity."
msgstr "Подключитесь через последовательный кабель (/dev/ttyUSB*), чтобы считать данные телефона."

msgid "This function is not wired up yet on this channel."
msgstr "Эта функция пока не реализована для данного канала."

msgid "Scanning Bluetooth…"
msgstr "Сканирование Bluetooth…"

msgid "No Bluetooth devices found"
msgstr "Устройства Bluetooth не найдены"

msgid "Make sure Bluetooth is on and nearby devices are discoverable."
msgstr "Убедитесь, что Bluetooth включён, а ближайшие устройства доступны для обнаружения."

msgid "Scanning Wi-Fi…"
msgstr "Сканирование Wi-Fi…"

msgid "No Wi-Fi networks found"
msgstr "Сети Wi-Fi не найдены"

msgid "No wireless networks are in range."
msgstr "В зоне действия нет беспроводных сетей."

msgid "Detecting devices…"
msgstr "Обнаружение устройств…"

msgid "Core not available"
msgstr "Ядро недоступно"

msgid "No phone or cable detected"
msgstr "Телефон или кабель не обнаружены"

msgid "Connect a Nokia phone via a DKU-2/CA-42 cable, then press the refresh button. Use Advanced to inspect every USB device."
msgstr "Подключите телефон Nokia с помощью кабеля DKU-2/CA-42, затем нажмите кнопку обновления. Используйте раздел «Дополнительно», чтобы просмотреть все устройства USB."

msgid "paired"
msgstr "сопряжено"

msgid "Scanning USB…"
msgstr "Сканирование USB…"

msgid "No USB devices visible to the host."
msgstr "Хост не видит ни одного устройства USB."

msgid "Connected USB devices"
msgstr "Подключённые устройства USB"

msgid "Advanced diagnostics"
msgstr "Расширенная диагностика"

msgid "Close"
msgstr "Закрыть"

msgid "Talk to legacy Nokia phones over FBUS/MBUS on modern Linux."
msgstr "Связь со старыми телефонами Nokia через FBUS/MBUS в современном Linux."

msgid "Identifying…"
msgstr "Идентификация…"

msgid "Phone identity"
msgstr "Данные телефона"

msgid "No reply."
msgstr "Нет ответа."

msgid "No serial port found — connect a DKU-2/CA-42 cable and try again."
msgstr "Последовательный порт не найден — подключите кабель DKU-2/CA-42 и повторите попытку."

msgid "Contacts"
msgstr "Контакты"

msgid "Fetching contacts…"
msgstr "Получение контактов…"

msgid "No contacts."
msgstr "Нет контактов."

msgid "Model"
msgstr "Модель"

msgid "Firmware"
msgstr "Прошивка"

msgid "Date"
msgstr "Дата"

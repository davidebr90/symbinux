msgid "Identify"
msgstr "Identificar"

msgid "Read model, IMEI and firmware"
msgstr "Ler modelo, IMEI e firmware"

msgid "Phonebook"
msgstr "Agenda"

msgid "Import / export contacts"
msgstr "Importar / exportar contactos"

msgid "SMS"
msgstr "SMS"

msgid "Read and send messages"
msgstr "Ler e enviar mensagens"

msgid "Netmonitor"
msgstr "Netmonitor"

msgid "Network diagnostics"
msgstr "Diagnóstico de rede"

msgid "Advanced"
msgstr "Avançado"

msgid "Raw USB/Bluetooth device list"
msgstr "Lista bruta de dispositivos USB/Bluetooth"

msgid "Rescan the selected channel"
msgstr "Reanalisar o canal selecionado"

msgid "Automatic"
msgstr "Automático"

msgid "Light"
msgstr "Claro"

msgid "Dark"
msgstr "Escuro"

msgid "Appearance"
msgstr "Aparência"

msgid "Language"
msgstr "Idioma"

msgid "About Symbinux"
msgstr "Acerca do Symbinux"

msgid "Connect over a serial cable (/dev/ttyUSB*) to read phone identity."
msgstr "Ligue através de um cabo série (/dev/ttyUSB*) para ler a identidade do telefone."

msgid "This function is not wired up yet on this channel."
msgstr "Esta função ainda não está disponível neste canal."

msgid "Scanning Bluetooth…"
msgstr "A analisar Bluetooth…"

msgid "No Bluetooth devices found"
msgstr "Nenhum dispositivo Bluetooth encontrado"

msgid "Make sure Bluetooth is on and nearby devices are discoverable."
msgstr "Certifique-se de que o Bluetooth está ligado e os dispositivos próximos estão detetáveis."

msgid "Scanning Wi-Fi…"
msgstr "A analisar Wi-Fi…"

msgid "No Wi-Fi networks found"
msgstr "Nenhuma rede Wi-Fi encontrada"

msgid "No wireless networks are in range."
msgstr "Nenhuma rede sem fios ao alcance."

msgid "Detecting devices…"
msgstr "A detetar dispositivos…"

msgid "Core not available"
msgstr "Núcleo não disponível"

msgid "No phone or cable detected"
msgstr "Nenhum telefone ou cabo detetado"

msgid "Connect a Nokia phone via a DKU-2/CA-42 cable, then press the refresh button. Use Advanced to inspect every USB device."
msgstr "Ligue um telefone Nokia com um cabo DKU-2/CA-42 e depois carregue no botão de atualização. Use Avançado para inspecionar todos os dispositivos USB."

msgid "paired"
msgstr "emparelhado"

msgid "Scanning USB…"
msgstr "A analisar USB…"

msgid "No USB devices visible to the host."
msgstr "Nenhum dispositivo USB visível para o anfitrião."

msgid "Connected USB devices"
msgstr "Dispositivos USB ligados"

msgid "Advanced diagnostics"
msgstr "Diagnóstico avançado"

msgid "Close"
msgstr "Fechar"

msgid "Talk to legacy Nokia phones over FBUS/MBUS on modern Linux."
msgstr "Comunique com telefones Nokia antigos por FBUS/MBUS em Linux moderno."

msgid "Identifying…"
msgstr "A identificar…"

msgid "Phone identity"
msgstr "Identidade do telefone"

msgid "No reply."
msgstr "Sem resposta."

msgid "No serial port found — connect a DKU-2/CA-42 cable and try again."
msgstr "Nenhuma porta série encontrada — ligue um cabo DKU-2/CA-42 e tente novamente."
